{
  "name": "@izimvo/backend",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "dev": "node --import tsx --watch src/server.ts",
    "start": "node --import tsx src/server.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:seed": "node --import tsx src/db/seed.ts"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "drizzle-kit": "^0.28.1",
    "drizzle-orm": "^0.36.4",
    "hono": "^4.6.13",
    "postgres": "^3.4.5",
    "tsx": "^4.19.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  }
}
