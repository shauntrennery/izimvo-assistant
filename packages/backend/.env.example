# Speechify (private session mode — these never reach the browser)
SPEECHIFY_API_KEY=
SPEECHIFY_AGENT_ID=
SPEECHIFY_WEBHOOK_HMAC_SECRET=
SPEECHIFY_TOOL_HMAC_SECRET=
SPEECHIFY_API_BASE=https://api.speechify.ai

# Shopify Global Catalog (client-credentials JWT)
SHOPIFY_CATALOG_CLIENT_ID=
SHOPIFY_CATALOG_CLIENT_SECRET=
SHOPIFY_CATALOG_TOKEN_URL=
SHOPIFY_CATALOG_MCP_URL=

# Postgres (Supabase)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/izimvo

# Attribution + public bases
ATTRIBUTION_UTM_SOURCE=izimvo
PUBLIC_API_BASE=https://api.izimvo.com
LOADER_CDN_BASE=https://cdn.izimvo.com

PORT=8787
